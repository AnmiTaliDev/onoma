---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';

const t = useTranslations();
const names = (await getCollection('names')).sort((a, b) => a.data.name.localeCompare(b.data.name));

const pickerData = JSON.stringify(
  names.map((e) => ({
    id: e.id,
    name: e.data.name,
    gender: e.data.gender,
    origin: e.data.origin,
    meaning: e.data.meaning,
  })),
);
---

<BaseLayout
  title={t('site.tagline')}
  description="Onoma is a reference for given names: their origins, meanings, and the etymological and cultural threads that connect them."
>
  <section class="lead">
    <h1>{t('site.title')}</h1>
    <p class="tagline">{t('site.tagline')}</p>
    <p class="prose">{t('home.lead')}</p>
    <div class="actions">
      <a href="/names/" class="button">{t('home.browseAll')}</a>
    </div>
  </section>

  <section class="name-of-day">
    <h2>{t('home.nameOfDay')}</h2>
    <div id="name-of-day"></div>
  </section>

  <script type="application/json" id="picker-data" set:html={pickerData} />
  <script>
    import { initNameOfDay } from '../scripts/name-of-day';

    const dataEl = document.getElementById('picker-data');
    const root = document.getElementById('name-of-day');
    if (dataEl?.textContent && root) {
      initNameOfDay(root, JSON.parse(dataEl.textContent));
    }
  </script>
</BaseLayout>

<style>
  .lead {
    padding-block: var(--space-6) var(--space-5);
    max-width: var(--content-width);
  }

  .tagline {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--ink-muted);
    font-style: italic;
    margin-bottom: var(--space-3);
  }

  .actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .name-of-day {
    border-top: 1px solid var(--border);
    padding-block: var(--space-5);
  }

  .name-of-day h2 {
    font-size: var(--step-0);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
    margin-bottom: var(--space-3);
  }
</style>
