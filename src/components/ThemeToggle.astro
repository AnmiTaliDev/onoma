---
import { useTranslations } from '../i18n';

const t = useTranslations();
---

<button id="theme-toggle" type="button" aria-label={t('nav.themeToggle')}>
  <span data-state="light">{t('nav.themeDark')}</span>
  <span data-state="dark">{t('nav.themeLight')}</span>
</button>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const isDark = root.dataset.theme === 'dark';
    if (isDark) {
      delete root.dataset.theme;
      localStorage.setItem('theme', 'light');
    } else {
      root.dataset.theme = 'dark';
      localStorage.setItem('theme', 'dark');
    }
  });
</script>

<style>
  button {
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    color: var(--ink-muted);
    text-decoration: none;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }

  button:hover {
    color: var(--ink);
  }

  [data-state='dark'] {
    display: none;
  }

  :global([data-theme='dark']) [data-state='light'] {
    display: none;
  }

  :global([data-theme='dark']) [data-state='dark'] {
    display: inline;
  }
</style>
